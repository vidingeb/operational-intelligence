@app.get("/ni/alerts")
def alerts(
    severity: Optional[str] = Query(None, description="Optional severity filter."),
    size: int = Query(50, description="Max number of results.")
):
    return {
        "status": "not_mapped",
        "message": "Session login and search are mapped. Alert endpoint still needs exact mapping from OpenAPI.",
        "requested_severity": severity,
        "size": size
    }


@app.get("/ni/flows")
def flows(
    source: Optional[str] = Query(None, description="Source VM/IP/entity."),
    destination: Optional[str] = Query(None, description="Destination VM/IP/entity."),
    port: Optional[str] = Query(None, description="Optional destination port."),
    protocol: Optional[str] = Query(None, description="Optional protocol TCP/UDP."),
    size: int = Query(50, description="Max number of results.")
):
    return {
        "status": "not_mapped",
        "message": "Session login and search are mapped. Flow endpoint still needs exact mapping from OpenAPI.",
        "source": source,
        "destination": destination,
        "port": port,
        "protocol": protocol,
        "size": size
    }
